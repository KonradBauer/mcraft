# Skopiuj do .env.production i uzupełnij wartości

# URL serwera (IP lub domena VPS, port 3000)
NEXT_PUBLIC_SERVER_URL=http://TWOJ_IP_VPS:9192

# Losowy sekret Payload — wygeneruj: openssl rand -hex 32
PAYLOAD_SECRET=WYGENERUJ_LOSOWY_SEKRET

# MongoDB jest wewnętrznie w Docker Compose — nie zmieniaj
# DATABASE_URL=mongodb://mongo:27017/mcraft
